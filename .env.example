# --- mochi-carry-signal configuration ---------------------------------------
# Copy to `.env` and fill in. All values have safe defaults except the secrets.
#
# PRODUCTION (Docker on Lightsail — see DEPLOY.md): set PM_BASE_URL to the PM's
# public URL, set a strong APP_SECRET, FUNDING_ARB_SECRET = the PM's secret, and
# (optionally) the LITESTREAM_* block at the bottom. DATABASE_URL is overridden by
# docker-compose.prod.yml, so leave it as-is.

# Position-manager (the funding-arb execution API we fire orders at).
# Local dev: http://localhost:8000.  Production (separate box): the PM's public
# URL, e.g. https://mochi-position-manager.duckdns.org
PM_BASE_URL=http://localhost:8000
# X-Arb-Secret header sent to the PM's /funding-arb/* routes. MUST equal the
# position-manager's FUNDING_ARB_SECRET. Empty => approve-to-fire will error.
FUNDING_ARB_SECRET=

# Gate for this app's approve / reject form POSTs. A pending signal can only be
# approved/rejected by a request carrying ?secret= (or form `secret`) == APP_SECRET.
# Empty => the gate is OPEN (fine for local dev; set it for any shared deploy).
APP_SECRET=

# Telegram — this app's OWN bot, SEPARATE from the position-manager's bot/chat.
# Create a distinct bot via @BotFather and use a distinct chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Signal parameters (LOCKED rule — change only deliberately).
# ASSETS: HL coins to WATCH (comma-string or JSON list). Any coin with both a
# perp (funding) and a spot market is a valid cash-and-carry candidate. *Firing*
# also requires the position-manager to list the asset in its funding-arb Asset
# enum — currently BTC/ETH/SOL/HYPE/PURR, so every coin below is fully end-to-end
# (watch -> record -> approve -> fire). Add a coin here only after the PM lists it.
ASSETS=BTC,ETH,SOL,HYPE,PURR
LOOKBACK_HOURS=72
ENTRY_APR=10.0
EXIT_APR=0.0
SIZE_MODE=min

# Poller cadence (seconds). 3600 = hourly; funding settles <= hourly.
POLL_SECONDS=3600

# Dashboard: rolling window (days) for the per-asset funding-history charts.
# Display only — the LOCKED signal still uses LOOKBACK_HOURS. Default ~6 months.
CHART_LOOKBACK_DAYS=180
# TTL (seconds) for the dashboard's in-memory funding fetch cache, so rapid page
# refreshes don't re-paginate months of HL history each load. The poller is
# never cached. 0 disables the cache.
CHART_CACHE_SECONDS=600

# Storage + runtime flags.
DATABASE_URL=sqlite:///./data/signals.db
LOG_LEVEL=INFO
# DRY_RUN mocks the PM HTTP call + Telegram (no outbound network). TESTING does
# the same and is what the test-suite sets. In production keep DRY_RUN=false so
# approvals actually fire to the PM (it's still approve-to-fire only — nothing
# fires without you clicking Approve). Set DRY_RUN=true to smoke-test first.
DRY_RUN=false
TESTING=false

# --- Backups: Litestream -> S3-compatible storage (continuous SQLite replication) ---
# Leave blank to disable — the `litestream` sidecar idles until these are set.
# Cloudflare R2 free tier recommended (10GB free): create a bucket + an R2 API token
# (Account > R2 > Manage API Tokens), then:
#   LITESTREAM_S3_REGION=auto
#   LITESTREAM_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# (AWS S3: set the bucket's region, leave endpoint blank. Backblaze B2: set its S3 endpoint.)
LITESTREAM_S3_BUCKET=
LITESTREAM_S3_ENDPOINT=
LITESTREAM_S3_REGION=auto
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
