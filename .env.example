# --- mochi-carry-signal configuration ---------------------------------------
# Copy to `.env` and fill in. All values have safe defaults except the secrets.

# Position-manager (the funding-arb execution API we fire orders at).
PM_BASE_URL=http://localhost:8000
# X-Arb-Secret header sent to the PM's /funding-arb/* routes. MUST equal the
# position-manager's FUNDING_ARB_SECRET. Empty => approve-to-fire will error.
FUNDING_ARB_SECRET=

# Gate for this app's approve / reject form POSTs. A pending signal can only be
# approved/rejected by a request carrying ?secret= (or form `secret`) == APP_SECRET.
# Empty => the gate is OPEN (fine for local dev; set it for any shared deploy).
APP_SECRET=

# Telegram — this app's OWN bot, SEPARATE from the position-manager's bot/chat.
# Create a distinct bot via @BotFather and use a distinct chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Signal parameters (LOCKED rule — change only deliberately).
ASSETS=["BTC","ETH","SOL"]
LOOKBACK_HOURS=72
ENTRY_APR=10.0
EXIT_APR=0.0
SIZE_MODE=min

# Poller cadence (seconds). 3600 = hourly; funding settles <= hourly.
POLL_SECONDS=3600

# Dashboard: rolling window (days) for the per-asset funding-history charts.
# Display only — the LOCKED signal still uses LOOKBACK_HOURS.
CHART_LOOKBACK_DAYS=30

# Storage + runtime flags.
DATABASE_URL=sqlite:///./data/signals.db
LOG_LEVEL=INFO
# DRY_RUN mocks the PM HTTP call + Telegram (no outbound network). TESTING does
# the same and is what the test-suite sets.
DRY_RUN=false
TESTING=false
